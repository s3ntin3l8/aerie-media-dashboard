# ============================================================
# AERIE — environment configuration
# Copy to `.env` and fill in for a real deployment:
#   cp .env.example .env
#
# Every value is OPTIONAL. With none set, AERIE runs in dev/mock
# mode: no OIDC (a dev admin "Dev User"), no upstream network calls,
# and an insecure built-in encryption key. Set the auth vars to
# turn on real Authentik login; set ENCRYPTION_KEY before storing
# any real service API keys. See lib/env.ts for the source of truth.
# ============================================================

# ── Authentik OIDC ──────────────────────────────────────────
# Auth is OFF until issuer + id + secret are ALL set (authConfigured
# in lib/env.ts). The `groups` scope is non-default — add a scope
# mapping in Authentik that emits it, or roles can't be derived.
AUTH_AUTHENTIK_ISSUER=https://authentik.example.com/application/o/aerie/
AUTH_AUTHENTIK_ID=
AUTH_AUTHENTIK_SECRET=

# Auth.js session secret. Required in production (without it Auth.js
# throws MissingSecret once OIDC is on). Generate: `openssl rand -base64 32`
AUTH_SECRET=

# Authentik group whose members get the admin role. Default: admins
AERIE_ADMIN_GROUP=admins

# ── Persistence ─────────────────────────────────────────────
# libSQL/SQLite URL. Default is a local file (gitignored). The Docker
# image overrides this to file:/app/data/aerie.db (a mounted volume).
DATABASE_URL=file:./data/aerie.db

# ── Secrets ─────────────────────────────────────────────────
# AES-256-GCM key for encrypting stored service API keys at rest.
# 32-byte hex or base64 (`openssl rand -hex 32`), or any string
# (stretched via sha256). A dev fallback key is used if unset — set a
# real one BEFORE entering any service secrets in Admin → Services.
ENCRYPTION_KEY=

# ── Declarative service config (optional) ───────────────────
# Path to a YAML file that defines services / visibility / secrets,
# so a deployment can be provisioned without the Admin UI. Default:
# ./config/aerie.yaml (copy config/aerie.example.yaml to start). The
# file is applied as a gap-fill on boot — it never overwrites existing
# DB rows or UI edits. Secrets in it are ${ENV_VAR} references resolved
# from the vars below; an unset var just leaves that service on mock data.
AERIE_CONFIG_FILE=./config/aerie.yaml

# Per-service API keys referenced by config/aerie.example.yaml. Set only
# the ones you use; leave the rest blank to keep those panels on mock data.
JELLYFIN_API_KEY=
OVERSEERR_API_KEY=
SONARR_API_KEY=
RADARR_API_KEY=
PROWLARR_API_KEY=
QBITTORRENT_API_KEY=
TAUTULLI_API_KEY=
JELLYSTAT_API_KEY=
GATUS_API_KEY=
PROMETHEUS_API_KEY=

# ── Branding / deployment ───────────────────────────────────
# Public origin of the portal — used for OIDC redirects and the
# `frame-ancestors` embed policy. Example: https://media.example.com
AERIE_PORTAL_URL=https://media.example.com

# Host only (no scheme), consumed PURELY by docker-compose for the Traefik
# router Host() rule (`${AERIE_DOMAIN}`). Not read by lib/env.ts.
AERIE_DOMAIN=media.example.com

# Display brand name. Default: AERIE
AERIE_BRAND=AERIE
