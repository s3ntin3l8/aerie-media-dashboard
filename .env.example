# ============================================================
# AERIE — environment configuration (copy to .env and fill in)
# Authentication is ALWAYS required. Configure OIDC below, or leave
# the OIDC vars empty and create a local admin on first run at /login.
# Service panels show real data only — empty until you store each
# service's API key in Admin → Services.
# ============================================================

# ── OIDC (any provider: Authentik, Keycloak, Google, Pocket-ID, Zitadel, …) ──
# OIDC is enabled only when issuer + client id + secret are all set.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Login button label / Auth.js provider name → "Continue with <name>"
OIDC_PROVIDER_NAME=SSO
# Auth.js provider id → callback path /api/auth/callback/<id>. Must match the
# redirect URI you register in your IdP. Default: oidc
OIDC_PROVIDER_ID=oidc
# Material-symbol icon name shown on the login button.
OIDC_PROVIDER_ICON=shield_person
# Requested scopes. `groups` is non-default; the IdP must emit it for role mapping.
OIDC_SCOPES=openid email profile groups
# Claim that carries group memberships (some IdPs use "roles").
OIDC_GROUPS_CLAIM=groups
# Group whose members get the admin role (default: admins)
AERIE_ADMIN_GROUP=admins
# Optional: comma-separated emails granted admin regardless of groups
# (useful for IdPs that don't emit a groups claim, e.g. Google).
AERIE_ADMIN_EMAILS=

# Auth.js session signing secret — generate with: openssl rand -base64 32
AUTH_SECRET=
# Optional: Aerie session lifetime in seconds (default 86400 = 24h). Keep it close to your
# upstream SSO (Authentik) session so Aerie's JWT doesn't outlive the forward-auth session
# behind embedded services. The JWT is sliding, so this bounds idle time, not active use.
# AUTH_SESSION_MAX_AGE=86400

# ── Persistence ──
# libSQL/SQLite URL. Default is a local file in ./data. For Turso use libsql://…
DATABASE_URL=file:./data/aerie.db
# 32-byte key for AES-256-GCM secret encryption — generate with: openssl rand -hex 32
ENCRYPTION_KEY=
# Docker only: host folder bind-mounted to /app/data (where aerie.db lives).
# Defaults to ./data. The container runs as AERIE_UID:AERIE_GID so it can write
# this folder — set these to the UID:GID that owns it (run `id` to find yours).
# AERIE_DATA_DIR=./data
# AERIE_UID=1000
# AERIE_GID=1000

# ── Declarative config (optional) ──
# Path to a YAML file that declares services/visibility/secrets to provision on boot.
AERIE_CONFIG_FILE=./config/aerie.yaml

# ── Branding / deployment ──
AERIE_BRAND=AERIE
AERIE_PORTAL_URL=https://media.s3ntin3l8.de
